-- ══════════════════════════════════════════
--  XCZ Function
-- ══════════════════════════════════════════
local function doXCZ()
    if xczCooldown then return end
    xczCooldown = true
    local char = player.Character
    if not char then xczCooldown = false return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then xczCooldown = false return end

    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Four, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Four, false, game)
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.W,    false, game)
    task.wait(0.01)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Q,    false, game)
    task.wait(0.03)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Q,    false, game)
    task.wait(0.04)
    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.pi, 0)
    task.wait(0.03)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W,    false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.One,  false, game)
    task.wait(0.02)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One,  false, game)
    task.wait(0.5)
    xczCooldown = false
end

-- ══════════════════════════════════════════
--  E Key — XCZ priority over Side Dash
-- ══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.E then
        if xczEnabled then
            task.spawn(doXCZ)
        end
    end
end)

-- ══════════════════════════════════════════
--  M1 Spam Loop
-- ══════════════════════════════════════════
task.spawn(function()
    local punchCount = 0
    while true do
        if m1Spam then
            local char = player.Character
            if char then
                local screenSize = workspace.CurrentCamera.ViewportSize
                local punchX = screenSize.X * 0.93
                local punchY = screenSize.Y * 0.50
                VirtualInputManager:SendMouseButtonEvent(punchX, punchY, 0, true,  game, 1)
                task.wait(0.05)
                VirtualInputManager:SendMouseButtonEvent(punchX, punchY, 0, false, game, 1)
                VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.One, false, game)
                task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                punchCount = punchCount + 1
                if xczEnabled and not xczCooldown and punchCount >= 4 then
                    punchCount = 0
                    task.spawn(doXCZ)
                end
            end
            task.wait(m1Delay)
        else
            punchCount = 0
            task.wait(0.05)
        end
    end
end)

-- ══════════════════════════════════════════
--  Loop Goto Heartbeat
-- ══════════════════════════════════════════
RunService.Heartbeat:Connect(function()
    if loopGoto and loopTargetName ~= "" then
        local target = Players:FindFirstChild(loopTargetName)
        if target and target.Character then
            local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
            local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if targetHRP and myHRP then
                myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, -2)
            end
        end
    end
end)

-- ══════════════════════════════════════════
--  Key Spam Loop
-- ══════════════════════════════════════════
task.spawn(function()
    while true do
        if keySpam then
            local keys = {
                Enum.KeyCode.One, Enum.KeyCode.Two,
                Enum.KeyCode.Three, Enum.KeyCode.Four,
            }
            for _, k in ipairs(keys) do
                if not keySpam then break end
                VirtualInputManager:SendKeyEvent(true,  k, false, game)
                task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, k, false, game)
                task.wait(spamDelay)
            end
        else
            task.wait(0.05)
        end
    end
end)

-- ══════════════════════════════════════════
--  Character Setup
-- ══════════════════════════════════════════
local function setupChar(char)
    if not char then return end
    local hum = char:WaitForChild("Humanoid")
    local hrp = char:WaitForChild("HumanoidRootPart")

    if deathTP and lastDeathCFrame then
        task.wait(0.15)
        hrp.CFrame = lastDeathCFrame
    end

    hum.Died:Connect(function()
        lastDeathCFrame = hrp.CFrame
        if autoReset then
            task.wait(resetDelay)
            player:LoadCharacter()
        end
    end)
end

if player.Character then setupChar(player.Character) end
player.CharacterAdded:Connect(setupChar)

