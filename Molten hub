loadstring([[

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local KEY = "sexy_Molten"

local function getRainbow(offset)
    offset = offset or 0
    local t = (tick() + offset) % 5 / 5
    return Color3.fromHSV(t, 1, 1)
end

local keyGui = Instance.new("ScreenGui")
keyGui.ResetOnSpawn = false
keyGui.Parent = playerGui

local keyFrame = Instance.new("Frame")
keyFrame.Size = UDim2.fromScale(0.3, 0.25)
keyFrame.AnchorPoint = Vector2.new(0.5,0.5)
keyFrame.Position = UDim2.fromScale(0.5,0.5)
keyFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
keyFrame.Parent = keyGui
Instance.new("UICorner", keyFrame)

local keyStroke = Instance.new("UIStroke", keyFrame)
keyStroke.Thickness = 3

local uiScale = Instance.new("UIScale", keyFrame)
uiScale.Scale = 0

local title = Instance.new("TextLabel", keyFrame)
title.Size = UDim2.fromScale(1, 0.3)
title.BackgroundTransparency = 1
title.Text = "Enter Key"
title.Font = Enum.Font.GothamBold
title.TextScaled = true
title.TextColor3 = Color3.new(1,1,1)

local keyBox = Instance.new("TextBox", keyFrame)
keyBox.Size = UDim2.fromScale(0.85, 0.25)
keyBox.Position = UDim2.fromScale(0.075, 0.4)
keyBox.PlaceholderText = "Key here"
keyBox.TextScaled = true
keyBox.Font = Enum.Font.Gotham
keyBox.BackgroundColor3 = Color3.fromRGB(45,45,45)
keyBox.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", keyBox)

local submit = Instance.new("TextButton", keyFrame)
submit.Size = UDim2.fromScale(0.5,0.2)
submit.Position = UDim2.fromScale(0.25,0.7)
submit.Text = "Unlock"
submit.TextScaled = true
submit.Font = Enum.Font.GothamBold
submit.BackgroundColor3 = Color3.fromRGB(60,60,60)
submit.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", submit)

local submitStroke = Instance.new("UIStroke", submit)
submitStroke.Thickness = 2

TweenService:Create(uiScale, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()

local keyRainbowConn
keyRainbowConn = RunService.Heartbeat:Connect(function()
    if not keyGui or not keyGui.Parent then
        keyRainbowConn:Disconnect()
        return
    end
    keyStroke.Color = getRainbow(0)
    submitStroke.Color = getRainbow(0.3)
    title.TextColor3 = getRainbow(0.6)
end)

local function startMainGui()
    TweenService:Create(uiScale, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0}):Play()
    task.wait(0.25)
    keyGui:Destroy()

    local keySpam = false
    local spamDelay = 0.12
    local deathTP = false
    local lastDeathCFrame
    local loopGoto = false
    local loopTargetName = ""
    local autoReset = false
    local resetDelay = 2
    local m1Spam = false
    local m1Delay = 0.1

    local gui = Instance.new("ScreenGui", playerGui)
    gui.ResetOnSpawn = false

    local toggleBtn = Instance.new("TextButton", gui)
    toggleBtn.Size = UDim2.fromScale(0.08, 0.06)
    toggleBtn.Position = UDim2.fromScale(0.01, 0.46)
    toggleBtn.Text = "⚡"
    toggleBtn.TextScaled = true
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.BackgroundColor3 = Color3.fromRGB(50,50,50)
    toggleBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", toggleBtn)
    local toggleStroke = Instance.new("UIStroke", toggleBtn)
    toggleStroke.Thickness = 2

    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.fromScale(0.55, 0.98)
    frame.Position = UDim2.fromScale(0.2, 0.01)
    frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    Instance.new("UICorner", frame)
    local frameStroke = Instance.new("UIStroke", frame)
    frameStroke.Thickness = 3

    local topBar = Instance.new("TextLabel", frame)
    topBar.Size = UDim2.fromScale(1, 0.07)
    topBar.Text = "Molten Hub"
    topBar.TextScaled = true
    topBar.Font = Enum.Font.GothamBold
    topBar.TextColor3 = Color3.new(1,1,1)
    topBar.BackgroundColor3 = Color3.fromRGB(25,25,25)
    Instance.new("UICorner", topBar)

    do
        local dragging, startPos, startInput
        topBar.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                startInput = i.Position
                startPos = frame.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if dragging then
                local delta = i.Position - startInput
                frame.Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            end
        end)
        UserInputService.InputEnded:Connect(function()
            dragging = false
        end)
    end

    local allStrokes = {frameStroke, toggleStroke}

    local function button(text, y)
        local b = Instance.new("TextButton", frame)
        b.Size = UDim2.fromScale(0.9, 0.06)
        b.Position = UDim2.fromScale(0.05, y)
        b.Text = text
        b.TextScaled = true
        b.Font = Enum.Font.GothamBold
        b.BackgroundColor3 = Color3.fromRGB(60,60,60)
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b)
        local s = Instance.new("UIStroke", b)
        s.Thickness = 2
        table.insert(allStrokes, s)
        return b
    end

    local function textbox(placeholder, default, y)
        local box = Instance.new("TextBox", frame)
        box.Size = UDim2.fromScale(0.9, 0.055)
        box.Position = UDim2.fromScale(0.05, y)
        box.PlaceholderText = placeholder
        box.Text = default or ""
        box.TextScaled = true
        box.Font = Enum.Font.Gotham
        box.BackgroundColor3 = Color3.fromRGB(45,45,45)
        box.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", box)
        return box
    end

    -- LoopGoto
    local gotoBtn = button("LoopGoto: OFF", 0.08)
    local nameBox = textbox("Username", "", 0.15)
    gotoBtn.MouseButton1Click:Connect(function()
        loopGoto = not loopGoto
        gotoBtn.Text = "LoopGoto: "..(loopGoto and "ON" or "OFF")
    end)
    nameBox.FocusLost:Connect(function()
        loopTargetName = nameBox.Text
    end)

    -- Key Spam
    local spamBtn = button("Key Spam: OFF", 0.23)
    local delayBox = textbox("Spam Delay (sec)", tostring(spamDelay), 0.30)
    spamBtn.MouseButton1Click:Connect(function()
        keySpam = not keySpam
        spamBtn.Text = "Key Spam: "..(keySpam and "ON" or "OFF")
    end)
    delayBox.FocusLost:Connect(function()
        local val = tonumber(delayBox.Text)
        if val and val >= 0.02 and val <= 1 then
            spamDelay = val
        else
            delayBox.Text = tostring(spamDelay)
        end
    end)

    -- AutoReset
    local resetBtn = button("AutoReset: OFF", 0.38)
    local resetBox = textbox("Reset Delay (sec)", tostring(resetDelay), 0.45)
    resetBtn.MouseButton1Click:Connect(function()
        autoReset = not autoReset
        resetBtn.Text = "AutoReset: "..(autoReset and "ON" or "OFF")
    end)
    resetBox.FocusLost:Connect(function()
        local val = tonumber(resetBox.Text)
        if val and val >= 0.05 and val <= 10 then
            resetDelay = val
        else
            resetBox.Text = tostring(resetDelay)
        end
    end)

    -- DeathTP
    local deathBtn = button("DeathTP: OFF", 0.53)
    deathBtn.MouseButton1Click:Connect(function()
        deathTP = not deathTP
        deathBtn.Text = "DeathTP: "..(deathTP and "ON" or "OFF")
    end)

    -- Teleport
    local tpBtn = button("📍 Teleport to Spot", 0.61)
    tpBtn.MouseButton1Click:Connect(function()
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(438.84, 439.51, -375.48) * CFrame.Angles(-0.00, 0.69, -0.00)
        end
    end)

    -- ✅ MOBILE M1 SPAM
    local m1Btn = button("👊 M1 Spam: OFF", 0.69)
    local m1DelayBox = textbox("M1 Delay (sec)", tostring(m1Delay), 0.76)

    m1Btn.MouseButton1Click:Connect(function()
        m1Spam = not m1Spam
        m1Btn.Text = "👊 M1 Spam: "..(m1Spam and "ON" or "OFF")
    end)
    m1DelayBox.FocusLost:Connect(function()
        local val = tonumber(m1DelayBox.Text)
        if val and val >= 0.02 and val <= 1 then
            m1Delay = val
        else
            m1DelayBox.Text = tostring(m1Delay)
        end
    end)

    -- Mobile M1 spam thread
    -- Finds the punch/fist button in the TSB mobile UI and fires it
    task.spawn(function()
        while true do
            if m1Spam then
                local char = player.Character
                if char then
                    -- Method 1: Simulate touch on the fist button position (right side of screen)
                    local screenSize = workspace.CurrentCamera.ViewportSize
                    -- Fist button is roughly at 93% X, 50% Y on screen based on TSB mobile layout
                    local punchX = screenSize.X * 0.93
                    local punchY = screenSize.Y * 0.50

                    VirtualInputManager:SendMouseButtonEvent(punchX, punchY, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(punchX, punchY, 0, false, game, 1)

                    -- Method 2: Also fire key 1 (Normal Punch mapped to key 1 in TSB)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                    task.wait(0.02)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                end
                task.wait(m1Delay)
            else
                task.wait(0.05)
            end
        end
    end)

    toggleBtn.MouseButton1Click:Connect(function()
        frame.Visible = not frame.Visible
    end)

    RunService.Heartbeat:Connect(function()
        local t = tick()
        for i, stroke in ipairs(allStrokes) do
            local hue = ((t * 0.3) + (i / #allStrokes)) % 1
            stroke.Color = Color3.fromHSV(hue, 1, 1)
        end
        topBar.TextColor3 = getRainbow(0.5)

        if loopGoto and loopTargetName ~= "" then
            local target = Players:FindFirstChild(loopTargetName)
            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-2)
                end
            end
        end

        if keySpam then
            local keys = {Enum.KeyCode.One, Enum.KeyCode.Two, Enum.KeyCode.Three, Enum.KeyCode.Four}
            for _, k in ipairs(keys) do
                if not keySpam then break end
                VirtualInputManager:SendKeyEvent(true, k, false, game)
                task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, k, false, game)
                task.wait(spamDelay)
            end
        end
    end)

    local function setupChar(char)
        if not char then return end
        local hum = char:WaitForChild("Humanoid")
        local hrp = char:WaitForChild("HumanoidRootPart")

        if deathTP and lastDeathCFrame then
            task.wait(0.15)
            hrp.CFrame = lastDeathCFrame
        end

        hum.Died:Connect(function()
            lastDeathCFrame = hrp.CFrame
            if autoReset then
                task.wait(resetDelay)
                player:LoadCharacter()
            end
        end)
    end

    if player.Character then setupChar(player.Character) end
    player.CharacterAdded:Connect(setupChar)
end

submit.MouseButton1Click:Connect(function()
    if keyBox.Text == KEY then
        startMainGui()
    else
        keyGui:Destroy()
    end
end)

]])()
