local function doXCZ()
    if xczCooldown then return end
    xczCooldown = true
    local char = player.Character
    if not char then xczCooldown = false return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then xczCooldown = false return end

    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Four, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Four, false, game)
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.W,    false, game)
    task.wait(0.01)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Q,    false, game)
    task.wait(0.03)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Q,    false, game)
    task.wait(0.04)
    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.pi, 0)
    task.wait(0.03)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W,    false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.One,  false, game)
    task.wait(0.02)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One,  false, game)
    task.wait(0.5)
    xczCooldown = false
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.E and xczEnabled then
        task.spawn(doXCZ)
    end
end)

