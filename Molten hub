local function showLoadingScreen(titleText, subTitleText, duration)
    local splash = Instance.new("ScreenGui", playerGui)
    splash.ResetOnSpawn = false
    splash.IgnoreGuiInset = true
    splash.DisplayOrder = 999

    local bg = Instance.new("Frame", splash)
    bg.Size = UDim2.fromScale(1, 1)
    bg.BackgroundColor3 = Color3.fromRGB(20, 0, 40)
    bg.BorderSizePixel = 0
    bg.BackgroundTransparency = 1

    local grad = Instance.new("UIGradient", bg)
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(76,  0,  130)),
        ColorSequenceKeypoint.new(0.3, Color3.fromRGB(138, 43, 226)),
        ColorSequenceKeypoint.new(0.6, Color3.fromRGB(75,  0,  130)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(148, 0,  211)),
    })
    grad.Rotation = 45

    local title = Instance.new("TextLabel", bg)
    title.Size = UDim2.fromScale(1, 0.22)
    title.Position = UDim2.fromScale(0, 0.22)
    title.BackgroundTransparency = 1
    title.Text = titleText
    title.Font = Enum.Font.GothamBold
    title.TextScaled = true
    title.TextColor3 = Color3.new(1, 1, 1)
    title.TextTransparency = 1

    local subTitle = Instance.new("TextLabel", bg)
    subTitle.Size = UDim2.fromScale(1, 0.12)
    subTitle.Position = UDim2.fromScale(0, 0.46)
    subTitle.BackgroundTransparency = 1
    subTitle.Text = subTitleText
    subTitle.Font = Enum.Font.GothamBold
    subTitle.TextScaled = true
    subTitle.TextColor3 = Color3.fromRGB(200, 100, 255)
    subTitle.TextTransparency = 1

    local credit = Instance.new("TextLabel", bg)
    credit.Size = UDim2.fromScale(1, 0.07)
    credit.Position = UDim2.fromScale(0, 0.60)
    credit.BackgroundTransparency = 1
    credit.Text = "Made by Molten 🔥"
    credit.Font = Enum.Font.Code
    credit.TextScaled = true
    credit.TextColor3 = Color3.fromRGB(180, 100, 255)
    credit.TextTransparency = 1

    local barBg = Instance.new("Frame", bg)
    barBg.Size = UDim2.new(0.6, 0, 0, 6)
    barBg.Position = UDim2.new(0.2, 0, 0.78, 0)
    barBg.BackgroundColor3 = Color3.fromRGB(60, 0, 100)
    barBg.BorderSizePixel = 0
    barBg.BackgroundTransparency = 1
    Instance.new("UICorner", barBg).CornerRadius = UDim.new(1, 0)

    local barFill = Instance.new("Frame", barBg)
    barFill.Size = UDim2.fromScale(0, 1)
    barFill.BackgroundColor3 = Color3.fromRGB(180, 0, 255)
    barFill.BorderSizePixel = 0
    Instance.new("UICorner", barFill).CornerRadius = UDim.new(1, 0)

    local loadingText = Instance.new("TextLabel", bg)
    loadingText.Size = UDim2.fromScale(1, 0.05)
    loadingText.Position = UDim2.fromScale(0, 0.86)
    loadingText.BackgroundTransparency = 1
    loadingText.Text = "Loading."
    loadingText.Font = Enum.Font.Code
    loadingText.TextScaled = true
    loadingText.TextColor3 = Color3.fromRGB(180, 100, 255)
    loadingText.TextTransparency = 1

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not splash or not splash.Parent then conn:Disconnect() return end
        grad.Rotation = (grad.Rotation + 0.5) % 360
        local hue = tick() * 0.25 % 1
        title.TextColor3 = Color3.fromHSV(hue, 0.4, 1)
        subTitle.TextColor3 = Color3.fromHSV((hue + 0.3) % 1, 0.6, 1)
        barFill.BackgroundColor3 = Color3.fromHSV((hue + 0.6) % 1, 1, 1)
        credit.TextColor3 = Color3.fromHSV((hue + 0.5) % 1, 0.5, 1)
    end)

    TweenService:Create(bg, TweenInfo.new(0.4), {BackgroundTransparency = 0}):Play()
    task.wait(0.3)
    TweenService:Create(barBg, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
    TweenService:Create(title, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
    task.wait(0.35)
    TweenService:Create(subTitle, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
    task.wait(0.3)
    TweenService:Create(credit, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
    task.wait(0.2)
    TweenService:Create(loadingText, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(barFill, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.fromScale(1, 1)}):Play()

    task.spawn(function()
        local dots = {"Loading.", "Loading..", "Loading...", "Loading...."}
        local i = 1
        while splash and splash.Parent do
            loadingText.Text = dots[i]
            i = i % #dots + 1
            task.wait(0.4)
        end
    end)

    task.wait(duration + 0.3)
    TweenService:Create(bg, TweenInfo.new(0.6), {BackgroundTransparency = 1}):Play()
    TweenService:Create(title, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
    TweenService:Create(subTitle, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
    TweenService:Create(credit, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
    TweenService:Create(loadingText, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
    TweenService:Create(barBg, TweenInfo.new(0.6), {BackgroundTransparency = 1}):Play()
    task.wait(0.7)
    conn:Disconnect()
    splash:Destroy()
end

