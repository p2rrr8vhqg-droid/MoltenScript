    -- XCZ function
    local function doXCZ()
        if xczCooldown then return end
        xczCooldown = true
        local char = player.Character
        if not char then xczCooldown = false return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then xczCooldown = false return end
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Four, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Four, false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
        task.wait(0.01)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
        task.wait(0.03)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
        task.wait(0.04)
        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.pi, 0)
        task.wait(0.03)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
        task.wait(0.5)
        xczCooldown = false
    end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.E and xczState() then
            task.spawn(doXCZ)
        end
    end)

    task.spawn(function()
        local punchCount = 0
        while true do
            if m1SpamState() then
                local char = player.Character
                if char then
                    local screenSize = workspace.CurrentCamera.ViewportSize
                    local punchX = screenSize.X * 0.93
                    local punchY = screenSize.Y * 0.50
                    VirtualInputManager:SendMouseButtonEvent(punchX, punchY, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(punchX, punchY, 0, false, game, 1)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                    task.wait(0.02)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                    punchCount = punchCount + 1
                    if xczState() and not xczCooldown and punchCount >= 4 then
                        punchCount = 0
                        task.spawn(doXCZ)
                    end
                end
                task.wait(m1Delay)
            else
