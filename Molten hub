                    c.HumanoidRootPart.Position + Vector3.new(20,20,20)
                )
                for _, part in ipairs(workspace:FindPartsInRegion3(region,nil,math.huge)) do
                    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health <= 0 and not processedHumanoids[hum] then
                        defeatedCount = defeatedCount + 1
                        processedHumanoids[hum] = true
                    end
                end
            end

