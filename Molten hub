-- ══════════════════════════════════════════
task.spawn(function()
    local punchCount = 0
    while true do
        if m1Spam then
            local char = player.Character
            if char then
                local ss = workspace.CurrentCamera.ViewportSize
                VirtualInputManager:SendMouseButtonEvent(ss.X*0.93, ss.Y*0.50, 0, true,  game, 1) task.wait(0.05)
                VirtualInputManager:SendMouseButtonEvent(ss.X*0.93, ss.Y*0.50, 0, false, game, 1)
                VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.One, false, game) task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                punchCount = punchCount + 1
                if xczEnabled and not xczCooldown and punchCount >= 4 then
                    punchCount = 0 task.spawn(doXCZ)
                end
            end
            task.wait(m1Delay)
        else
            punchCount = 0 task.wait(0.05)
        end
    end
end)

